rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    match /services/{document} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/{document} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Allow admins or the owner of the user document to update or delete their profile.
      allow update, delete: if isAdmin() || (isSignedIn() && (request.auth.uid == resource.data.uid || request.auth.uid == document));
    }

    match /shop/{document} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.uploadedBy;
      allow update, delete: if isAdmin();
    }

    match /shop-purchases/{document} {
      allow read: if isSignedIn();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /developer-applications/{document} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /developers/{document} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /store-assets/{document} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.uploadedBy;
      allow update, delete: if isAdmin();
    }

    match /requests/{document} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
